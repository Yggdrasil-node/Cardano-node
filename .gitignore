# Generated by Cargo
/target/
**/target/
tmp/

# rustfmt backups
**/*.rs.bk

# MSVC Windows builds of rustc generate these (debugging information)
*.pdb

# cargo mutants
**/mutants.out*/

# cargo expand / cargo audit local caches
.cargo-expand/
.codex-tools/

# RustRover / JetBrains
#.idea/

# VS Code (per-user; teams usually share .vscode in the repo if at all)
.vscode/*
!.vscode/settings.example.json

# Claude Code local-only state (per-machine, not committed)
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Operator-side local files (do NOT commit secrets)
*.skey
*.opcert
*.counter
*.pem
*.key
.env
.env.*
!.env.example

# Local node data dirs
**/db/
**/chain/
**/ledger/
# Don't ignore the source crate, which happens to share the name.
!crates/ledger/
!crates/ledger/**
wallet/
metadata/
keys/
certs/

# Jekyll docs site (built in CI; do not commit local builds)
docs/_site/
docs/.jekyll-cache/
docs/.jekyll-metadata
docs/.bundle/
docs/vendor/
docs/Gemfile.lock

# Docker artifacts
.docker/
docker-compose.override.yml
**/.dockerignore.local

# OS clutter
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Backups produced by scripts/backup_db.sh when run locally
*.tar.gz.sha256
yggdrasil-db-*.tar.gz

# Vendored metadata-free reference copies of upstream IntersectMBO source / binaries.
# These are local-only references for parity research (see AGENTS.md and
# docs/UPSTREAM_PARITY.md). They MUST NOT enter the index — Yggdrasil is a
# clean-room port and treats upstream code as documentation only.
**/.reference-haskell-cardano-node/
**/.referance-haskell-install/
**/.reference-haskell-install/

# Local logs
*.log
# Anchored to repo root so it doesn't swallow source dirs like
# `crates/tools/cardano-tracer/src/handlers/logs/` (R382).
/logs/
**/run/logs/
**/*-runtime-logs/
# Forensic captures referenced by tests (include_str! in plutus_eval/tests.rs)
# must be committed even though they end in .log. Pinned via explicit
# exception so the *.log rule above stays the safe default for everyone else.
!docs/operational-runs/*.log

# Coverage / profiling
*.profraw
coverage/
lcov.info

# Generated tx-generator selftest output
/crates/tools/tx-generator/plutus-budget-summary.json

# Python tooling artifacts
__pycache__/
*.pyc
