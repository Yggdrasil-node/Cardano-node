# Generated by Cargo
debug
target
tmp
**/target/

# rustfmt backups
**/*.rs.bk

# MSVC Windows builds of rustc generate these (debugging information)
*.pdb

# cargo mutants
**/mutants.out*/

# cargo expand / cargo audit local caches
.cargo-expand/

# RustRover / JetBrains
#.idea/

# VS Code (per-user; teams usually share .vscode in the repo if at all)
.vscode/*
!.vscode/settings.example.json

# Operator-side local files (do NOT commit secrets)
*.skey
*.opcert
*.counter
*.pem
*.key
.env
.env.*
!.env.example

# Local node data dirs
**/db/
**/chain/
**/ledger/
wallet/
metadata/
keys/
certs/

# Jekyll docs site (built in CI; do not commit local builds)
docs/_site/
docs/.jekyll-cache/
docs/.jekyll-metadata
docs/.bundle/
docs/vendor/
docs/Gemfile.lock

# Docker artifacts
.docker/
docker-compose.override.yml
**/.dockerignore.local

# OS clutter
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Backups produced by node/scripts/backup_db.sh when run locally
*.tar.gz.sha256
yggdrasil-db-*.tar.gz

# Local logs
*.log
logs/

# Coverage / profiling
*.profraw
coverage/
lcov.info
