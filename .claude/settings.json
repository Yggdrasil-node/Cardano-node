{
  "env": {
    "CARGO_TERM_COLOR": "always",
    "RUST_BACKTRACE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cargo fmt*)",
      "Bash(cargo check*)",
      "Bash(cargo check-all)",
      "Bash(cargo test*)",
      "Bash(cargo test-all)",
      "Bash(cargo clippy*)",
      "Bash(cargo lint)",
      "Bash(cargo build*)",
      "Bash(cargo doc*)",
      "Bash(cargo fetch*)",
      "Bash(cargo metadata*)",
      "Bash(cargo tree*)",
      "Bash(rustup show*)",
      "Bash(rustc --version)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git ls-files*)",
      "Bash(git ls-tree*)",
      "Bash(git grep*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git cat-file*)",
      "Bash(rg*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(ls*)",
      "Bash(wc*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(awk*)",
      "Bash(sed -n*)",
      "Bash(cut*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(diff*)",
      "Bash(file*)",
      "Bash(chmod +x*)",
      "Bash(mkdir -p*)",
      "Bash(python3 scripts/check-parity-matrix.py*)",
      "Bash(python3 .claude/scripts/filetree.py*)",
      "Bash(jq -e*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"Yggdrasil verification gates: cargo fmt --all -- --check, cargo check-all, cargo lint, cargo test-all must all pass; for protocol/ledger/Plutus/network/storage changes also run python3 scripts/check-parity-matrix.py; for filename-mirror restructures also run python3 .claude/scripts/filetree.py check.\"}'"
          }
        ]
      }
    ]
  }
}
